  descripcion String
  esTercero   Boolean   @default(false) // LLT/DMT/DMS => contacto sensible
  estado      Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  gestiones      tbl_gestion[]
  tipificaciones tbl_mandante_tipificacion[]

  @@map("tbl_codigo_accion")
}

model tbl_codigo_resultado {
  idcodresultado Int       @id @default(autoincrement())
  codigo         String    @unique // PRP, CDP, PNC, ILC, CAN, TLE...
  descripcion    String
  grupo          String // LOCALIZADO / TERCERO / SIN CONTACTO / CANCELADA
  tipoGestion    String // EFECTIVA / EFECTIVA CON TERCERO / COMPLEMENTO
  estado         Boolean   @default(true)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  gestiones      tbl_gestion[]
  tipificaciones tbl_mandante_tipificacion[]

  @@map("tbl_codigo_resultado")
}

model tbl_mandante_tipificacion {
  idmt           Int      @id @default(autoincrement())
  idmandante     Int
  idcodaccion    Int?
  idcodresultado Int?
  activo         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  mandante  tbl_mandante          @relation(fields: [idmandante], references: [idmandante])
  codaccion tbl_codigo_accion?    @relation(fields: [idcodaccion], references: [idcodaccion])
  codresult tbl_codigo_resultado? @relation(fields: [idcodresultado], references: [idcodresultado])

  @@index([idmandante])
  @@map("tbl_mandante_tipificacion")
}

model tbl_gestion {
  idmandante          Int // denormalizado para scope/reportes
  idgestion           Int       @id @default(autoincrement())
  idprestamo          Int
  idgestor            Int // tbl_usuario
  idcodaccion         Int?
  idcodresultado      Int?
  fechaGestion        DateTime  @default(now())
  telefonoContacto    String?
  contactoTercero     Boolean   @default(false) // requiere justificación (Ley 787)
  nota                String    @db.Text
  razonMora           String?
  montoPromesa        Decimal?  @db.Decimal(14, 2)
  fechaPromesa        DateTime?
  /// PENDIENTE | CUMPLIDA | VENCIDA (H16); null si no hay promesa.
  estadoPromesa       String?   @db.VarChar(16)
  fechaProximaGestion DateTime?
  comentario          String?   @db.Text
  latitud             Decimal?  @db.Decimal(9, 6) // gestión de campo
  longitud            Decimal?  @db.Decimal(9, 6)
  /** Idempotency offline/PWA (I036); único por gestor. */
  idempotencyKey      String?   @db.VarChar(64)
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  mandante  tbl_mandante          @relation(fields: [idmandante], references: [idmandante])
  prestamo  tbl_prestamo          @relation(fields: [idprestamo], references: [idprestamo])
  gestor    tbl_usuario           @relation(fields: [idgestor], references: [idusuario])
  codaccion tbl_codigo_accion?    @relation(fields: [idcodaccion], references: [idcodaccion])
  codresult tbl_codigo_resultado? @relation(fields: [idcodresultado], references: [idcodresultado])

  acuerdos tbl_acuerdo[]
  pagos    tbl_pago[]

  @@unique([idgestor, idempotencyKey])
  @@index([idmandante, fechaGestion])
  @@index([idprestamo])
  @@index([idgestor])
  @@index([idgestor, fechaGestion])
  @@index([idgestor, fechaProximaGestion, deletedAt])
  @@index([idmandante, deletedAt, fechaPromesa])
  @@index([fechaPromesa])
  @@index([estadoPromesa, fechaPromesa])
  @@map("tbl_gestion")
}

// ============================================
// COBRANZA · ACUERDOS / DESCUENTOS / PAGOS / LIQUIDACIÓN
// ============================================

model tbl_politica_descuento {
  idpolitica   Int       @id @default(autoincrement())
  idmandante   Int
  tramoMoraMin Int
  tramoMoraMax Int?
  porcentaje   Decimal   @db.Decimal(5, 2)
  estado       Boolean   @default(true)
  vigenteDesde DateTime  @default(now())
  vigenteHasta DateTime?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  mandante tbl_mandante @relation(fields: [idmandante], references: [idmandante])

  @@index([idmandante])
  @@index([idmandante, vigenteDesde, vigenteHasta])
  @@map("tbl_politica_descuento")
}

model tbl_acuerdo {
  idacuerdo      Int       @id @default(autoincrement())
  idmandante     Int
  idprestamo     Int
  idgestion      Int?
  baseNegociable Decimal   @db.Decimal(14, 2) // saldo + moratorio/gestión no dispensados
  porcentajeDesc Decimal   @db.Decimal(5, 2)
  montoDescuento Decimal   @db.Decimal(14, 2) // base * %
  montoAcordado  Decimal   @db.Decimal(14, 2) // base - descuento
  dispensarInteresMoratorio Boolean @default(false)
  dispensarGestionCobranza  Boolean @default(false)
  numeroCuotas   Int       @default(1)
  montoCuota     Decimal   @db.Decimal(14, 2) // acordado / cuotas
  pagoMinimo     Decimal?  @db.Decimal(14, 2) // cuota / 2
  fechaInicio    DateTime
  estado         String // VIGENTE / CUMPLIDO / ROTO
  /// Lock optimista (I019).
  version        Int       @default(0)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  mandante tbl_mandante @relation(fields: [idmandante], references: [idmandante])
  prestamo tbl_prestamo @relation(fields: [idprestamo], references: [idprestamo])
  gestion  tbl_gestion? @relation(fields: [idgestion], references: [idgestion])
  pagos    tbl_pago[]
  cuotas   tbl_acuerdo_cuota[]

  @@index([idmandante])
  @@index([idprestamo])
  @@index([estado, deletedAt])
  @@map("tbl_acuerdo")
}

model tbl_pago {
  idpago     Int       @id @default(autoincrement())
  idmandante Int
  idprestamo Int
  idacuerdo  Int?
  idgestion  Int?
  idgestor   Int? // cobrador que registró el pago
  fechaPago  DateTime
  monto      Decimal   @db.Decimal(14, 2)
  moneda     String    @default("NIO")
  tipoCambio Decimal?  @db.Decimal(10, 4)
  /// Catálogo: EFECTIVO | TRANSFERENCIA | DEPOSITO | CHEQUE | TARJETA | OTRO (Zod MEDIOS_PAGO).
  medio      String? @db.VarChar(32)
  /// Clave de idempotencia del cliente (reintentos no duplican pago).
  idempotencyKey String? @db.VarChar(64)
  aplicado   Boolean   @default(false) // conciliación con siguiente corte
  /// Snapshot de mora al aplicar el pago (comisiones / liquidación).
  diasMoraAplicacion Int?
  /// Folio comprobante FlowPay (I072); único; se setea tras create (MariaDB no permite GENERATED sobre AUTO_INCREMENT).
  folio      String?   @unique @db.VarChar(16)
  /// JSON de waterfall de aplicación (H04); permite reverso exacto de componentes.
  aplicacionJson String? @db.VarChar(512)
  reciboUrl  String?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  mandante tbl_mandante @relation(fields: [idmandante], references: [idmandante])
  prestamo tbl_prestamo @relation(fields: [idprestamo], references: [idprestamo])
  acuerdo  tbl_acuerdo? @relation(fields: [idacuerdo], references: [idacuerdo])
  gestion  tbl_gestion? @relation(fields: [idgestion], references: [idgestion])
  gestor   tbl_usuario? @relation(fields: [idgestor], references: [idusuario])
  liquidacionDetalles tbl_liquidacion_detalle[]

  @@index([idmandante])
  @@index([idprestamo])
  @@index([idgestor])
  @@index([fechaPago, aplicado])
  @@index([idmandante, deletedAt, aplicado, fechaPago])
  @@index([idprestamo, fechaPago, monto, medio])
  @@unique([idgestor, idempotencyKey])
  @@map("tbl_pago")
}

model tbl_liquidacion {
  idliquidacion   Int       @id @default(autoincrement())
  idmandante      Int
  periodo         String // "2026-03"
  /// Igual a periodo si activa; null si soft-delete (permite unique con MySQL).
  periodoActivo   String?
  /// Moneda de reporte de la liquidación (H25); montos convertidos a esta base.
  moneda          String    @default("NIO") @db.VarChar(3)
  totalRecuperado Decimal   @db.Decimal(14, 2)
  totalComision   Decimal   @db.Decimal(14, 2)
  estado          String // BORRADOR / EMITIDA / PAGADA
  idusuarioCreacion Int?
  idusuarioEmision  Int?
  /** Idempotency key de generarLiquidacion (I015); único por mandante. */
  idempotencyKey  String?   @db.VarChar(64)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  mandante tbl_mandante @relation(fields: [idmandante], references: [idmandante])
  detalle  tbl_liquidacion_detalle[]
  usuarioCreacion tbl_usuario? @relation("LiquidacionCreacion", fields: [idusuarioCreacion], references: [idusuario])
  usuarioEmision  tbl_usuario? @relation("LiquidacionEmision", fields: [idusuarioEmision], references: [idusuario])

  @@unique([idmandante, periodoActivo])
  @@unique([idmandante, idempotencyKey])
  @@index([idmandante])
  @@index([idmandante, periodo, deletedAt])
  @@map("tbl_liquidacion")
}

model tbl_liquidacion_detalle {
  iddetalle                  Int     @id @default(autoincrement())
  idliquidacion              Int
  idpago                     Int
  idprestamo                 Int
  noPrestamo                 String
  /** Monto en moneda base de la liquidación. */
  monto                      Decimal @db.Decimal(14, 2)
  monedaOriginal             String  @default("NIO") @db.VarChar(3)
  montoOriginal              Decimal @db.Decimal(14, 2)
  tipoCambioAplicado         Decimal @default(1) @db.Decimal(10, 4)
  diasMora                   Int
  idgestor                   Int?
  nombreGestor               String?
  porcentajeRecuperacion     Decimal @db.Decimal(5, 2)
  ingresoEmpresa             Decimal @db.Decimal(14, 2)
  porcentajeComisionCobrador Decimal @db.Decimal(5, 2)
  montoComision              Decimal @db.Decimal(14, 2)
  createdAt                  DateTime @default(now())

  liquidacion tbl_liquidacion @relation(fields: [idliquidacion], references: [idliquidacion], onDelete: Cascade)
  pago        tbl_pago        @relation(fields: [idpago], references: [idpago])
  prestamo    tbl_prestamo    @relation(fields: [idprestamo], references: [idprestamo])

  @@unique([idpago])
  @@index([idliquidacion])
  @@index([idprestamo])
  @@map("tbl_liquidacion_detalle")
}

model tbl_acuerdo_cuota {
  idcuota           Int      @id @default(autoincrement())
  idacuerdo         Int
  numeroCuota       Int
  montoCuota        Decimal  @db.Decimal(14, 2)
  fechaVencimiento  DateTime
  estado            String   @default("PENDIENTE") // PENDIENTE / PAGADA / VENCIDA
  idpago            Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

