// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

generator pothos {
  provider           = "prisma-pothos-types"
  clientOutput       = "@prisma/client"
  generateDatamodel  = "true"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// CATÁLOGOS
// ============================================

model tbl_pais {
  idpais      Int      @id @default(autoincrement())
  codepais    String
  descripcion String
  estado      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  departamentos tbl_departamento[]
  clientes      tbl_cliente[]
  feriados      tbl_dia_feriado[]

  @@map("tbl_pais")
}

model tbl_departamento {
  iddepartamento Int      @id @default(autoincrement())
  idpais         Int
  descripcion    String
  estado         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  pais     tbl_pais      @relation(fields: [idpais], references: [idpais])
  clientes tbl_cliente[]

  @@map("tbl_departamento")
}

model tbl_estadocivil {
  idestadocivil Int      @id @default(autoincrement())
  descripcion   String
  estado        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  clientes tbl_cliente[]

  @@map("tbl_estadocivil")
}

model tbl_ocupacion {
  idocupacion Int      @id @default(autoincrement())
  descripcion String
  estado      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clientes tbl_cliente[]

  @@map("tbl_ocupacion")
}

model tbl_tipodocumento {
  idtipodocumento Int      @id @default(autoincrement())
  descripcion     String
  estado          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clientes tbl_cliente[]

  @@map("tbl_tipodocumento")
}

model tbl_tipopersona {
  idtipopersona Int      @id @default(autoincrement())
  descripcion   String
  estado        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  clientes tbl_cliente[]

  @@map("tbl_tipopersona")
}

model tbl_genero {
  idgenero    Int      @id @default(autoincrement())
  descripcion String
  estado      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clientes tbl_cliente[]

  @@map("tbl_genero")
}

// ============================================
// CLIENTES
// ============================================

model tbl_cliente {
  idcliente Int @id @default(autoincrement())

  // Información personal
  primer_nombres   String
  segundo_nombres  String?
  primer_apellido  String
  segundo_apellido String?
  fechanacimiento  DateTime?

  // Documento de identidad
  idtipodocumento     Int
  numerodocumento     String    @unique
  fechavencimientodoc DateTime?

  // Información demográfica
  idgenero      Int?
  idestadocivil Int?
  idocupacion   Int?
  idtipopersona Int

  // Ubicación
  idpais         Int
  iddepartamento Int?
  direccion      String?
  ciudad         String?
  codigopostal   String?

  // Contacto
  telefono String?
  celular  String?
  email    String? @unique
  sitioweb String?
  espep    Boolean @default(false)

  // Información adicional
  observaciones String?  @db.Text
  estado        Boolean  @default(true)
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relaciones
  tipodocumento tbl_tipodocumento @relation(fields: [idtipodocumento], references: [idtipodocumento])
  genero        tbl_genero?       @relation(fields: [idgenero], references: [idgenero])
  estadocivil   tbl_estadocivil?  @relation(fields: [idestadocivil], references: [idestadocivil])
  ocupacion     tbl_ocupacion?    @relation(fields: [idocupacion], references: [idocupacion])
  tipopersona   tbl_tipopersona   @relation(fields: [idtipopersona], references: [idtipopersona])
  pais          tbl_pais          @relation(fields: [idpais], references: [idpais])
  departamento  tbl_departamento? @relation(fields: [iddepartamento], references: [iddepartamento])

  // Relaciones de cobranza: cliente = deudor master compartido (H21).
  // Acceso multi-tenant vía préstamos del mandante, no por idmandante en esta tabla.
  prestamos  tbl_prestamo[]
  contactos  tbl_deudor_contacto[]
  reclamos   tbl_reclamo[]
  documentos tbl_documento[]

  @@index([numerodocumento])
  @@index([email])
  @@index([idtipodocumento])
  @@index([idpais])
  @@index([deletedAt])
  @@map("tbl_cliente")
}

// ============================================
// USUARIOS Y ROLES
// ============================================

model tbl_rol {
  idrol       Int       @id @default(autoincrement())
  codigo      String    @unique
  descripcion String
  estado      Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  usuarios tbl_usuario[]
  permisos tbl_rol_permiso[]

  @@map("tbl_rol")
}

model tbl_usuario {
  idusuario         Int       @id @default(autoincrement())
  idrol             Int
  idsupervisor      Int?
  nombre            String
  email             String    @unique
  telefono          String?
  porcentajeComision Decimal  @default(0) @db.Decimal(5, 2) // % sobre ingreso empresa
  passwordHash      String? // bcrypt
  salt         String? // vacío con bcrypt (compat)
  mfaEnabled   Boolean  @default(false)
  mfaSecret    String?  // Secreto TOTP cifrado (AES-GCM)
  mfaEnabledAt DateTime?
  ultimoAcceso DateTime? // Último acceso al sistema
  activo       Boolean   @default(true)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  rol tbl_rol @relation(fields: [idrol], references: [idrol])
  supervisor tbl_usuario?  @relation("usuario_supervisor", fields: [idsupervisor], references: [idusuario], onDelete: NoAction, onUpdate: NoAction)
  subordinados tbl_usuario[] @relation("usuario_supervisor")

  configuracionesModificadas tbl_configuracion_sistema[] @relation("usuario_config_mod")
  auditorias                 tbl_auditoria[]

  // Relaciones de cobranza
  gestiones                    tbl_gestion[]
  prestamosAsignados           tbl_prestamo[]
  mandantes                    tbl_usuario_mandante[]
  pagosRegistrados             tbl_pago[]
  cargasCartera                tbl_carga_cartera[]
  importacionJobs              tbl_importacion_job[]
  exportacionJobs              tbl_exportacion_job[]
  asignacionesRealizadas       tbl_prestamo_asignacion_historial[] @relation("usuario_asignacion")
  asignacionesGestorAnterior   tbl_prestamo_asignacion_historial[] @relation("gestor_anterior")
  asignacionesGestorNuevo      tbl_prestamo_asignacion_historial[] @relation("gestor_nuevo")
  estadosPrestamoRegistrados   tbl_prestamo_estado_historial[]
  notificacionesLeidas         tbl_notificacion_lectura[]
  notificaciones               tbl_notificacion[]
  liquidacionesCreadas         tbl_liquidacion[] @relation("LiquidacionCreacion")
  liquidacionesEmitidas        tbl_liquidacion[] @relation("LiquidacionEmision")

  @@index([idrol])
  @@index([idsupervisor])
  @@index([email])
  @@index([deletedAt])
  @@map("tbl_usuario")
}

model tbl_auditoria {
  idauditoria Int      @id @default(autoincrement())
  idusuario   Int?
  entidad     String
  entidadId   Int?
  accion      String
  detalle     String?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  usuario tbl_usuario? @relation(fields: [idusuario], references: [idusuario])

  @@index([entidad, entidadId])
  @@index([idusuario])
  @@index([createdAt])
  @@index([accion])
  @@map("tbl_auditoria")
}

// ============================================
// CONFIGURACIÓN DEL SISTEMA
// ============================================

model tbl_configuracion_sistema {
  idconfiguracion Int       @id @default(autoincrement())
  clave           String    @unique
  valor           String    @db.Text
  tipo            String // "numero", "decimal", "texto", "json", "booleano"
  descripcion     String?   @db.Text
  categoria       String? // "general"
  idusuarioMod    Int?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  usuarioMod tbl_usuario? @relation("usuario_config_mod", fields: [idusuarioMod], references: [idusuario])

  @@index([clave, deletedAt])
  @@index([categoria, deletedAt])
  @@map("tbl_configuracion_sistema")
}

// ============================================
// PERMISOS Y ROLES (RBAC)
// ============================================

model tbl_permiso {
  idpermiso   Int       @id @default(autoincrement())
  codigo      String    @unique
  nombre      String // Nombre legible del permiso
  descripcion String?   @db.Text
  categoria   String? // "CONFIGURACION"
  estado      Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  roles tbl_rol_permiso[]

  @@index([codigo, deletedAt])
  @@index([categoria, deletedAt])
  @@map("tbl_permiso")
}

model tbl_rol_permiso {
  idrolPermiso Int      @id @default(autoincrement())
  idrol        Int
  idpermiso    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  rol     tbl_rol     @relation(fields: [idrol], references: [idrol], onDelete: Cascade)
  permiso tbl_permiso @relation(fields: [idpermiso], references: [idpermiso], onDelete: Cascade)

  @@unique([idrol, idpermiso], name: "idrol_idpermiso")
  @@index([idrol])
  @@index([idpermiso])
  @@map("tbl_rol_permiso")
}

// ============================================
// COBRANZA · CATÁLOGOS ORGANIZATIVOS Y DE PRODUCTO
// ============================================

model tbl_agencia {
  idagencia  Int       @id @default(autoincrement())
  /// Tenant (H21); agencia pertenece a un mandante.
  idmandante Int
  codigo     String
  nombre     String
  estado     Boolean   @default(true)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  mandante  tbl_mandante   @relation(fields: [idmandante], references: [idmandante])
  rutas     tbl_ruta[]
  prestamos tbl_prestamo[]

  @@unique([idmandante, codigo])
  @@index([idmandante])
  @@index([deletedAt])
  @@map("tbl_agencia")
}

model tbl_ruta {
  idruta    Int       @id @default(autoincrement())
  idagencia Int
  nombre    String
  estado    Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  agencia   tbl_agencia    @relation(fields: [idagencia], references: [idagencia])
  prestamos tbl_prestamo[]

  @@index([idagencia])
  @@map("tbl_ruta")
}

model tbl_tipocredito {
  idtipocredito Int       @id @default(autoincrement())
  descripcion   String
  estado        Boolean   @default(true)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  prestamos tbl_prestamo[]

  @@map("tbl_tipocredito")
}

model tbl_modelopago {
  idmodelopago Int       @id @default(autoincrement())
  descripcion  String // Semanal / Quincenal / Mensual / Diario
  estado       Boolean   @default(true)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  prestamos tbl_prestamo[]

  @@map("tbl_modelopago")
}

// ============================================
// COBRANZA · MANDANTE (ACREEDOR / CLIENTE DE LA AGENCIA)
// ============================================

model tbl_mandante {
  idmandante      Int       @id @default(autoincrement())
  codigo          String    @unique
  nombre          String
  ruc             String?
  regulador       String? // CONAMI / SIBOIF / NINGUNO (define reglas de compliance)
  descuentoMaximo Decimal   @default(100) @db.Decimal(5, 2) // % máximo autorizado en acuerdos
  estado          Boolean   @default(true)
  /** URL HTTPS del receptor de webhooks (I054). */
  webhookUrl      String?   @db.VarChar(500)
  /** Secreto HMAC; no exponer en GraphQL de lectura. */
  webhookSecret   String?   @db.VarChar(128)
  webhookActivo   Boolean   @default(false)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  contratos             tbl_contrato_mandante[]
  comisiones            tbl_comision_cobro[]
  campanas              tbl_campana[]
  prestamos             tbl_prestamo[]
  gestiones             tbl_gestion[]
  acuerdos              tbl_acuerdo[]
  pagos                 tbl_pago[]
  liquidaciones         tbl_liquidacion[]
  politicasDescuento    tbl_politica_descuento[]
  tipificaciones        tbl_mandante_tipificacion[]
  plantillasImportacion tbl_plantilla_importacion[]
  plantillasMensaje     tbl_plantilla_mensaje[]
  horarios              tbl_horario_cobranza[]
  reclamos              tbl_reclamo[]
  usuarios              tbl_usuario_mandante[]
  cargasCartera         tbl_carga_cartera[]
  importacionJobs       tbl_importacion_job[]
  secuenciasContacto    tbl_secuencia_contacto[]
  resumenesDiarios      tbl_resumen_diario_cobranza[]
  exportacionJobs       tbl_exportacion_job[]
  refinanciamientos     tbl_refinanciamiento[]
  agencias              tbl_agencia[]

  @@index([deletedAt])
  @@map("tbl_mandante")
}

model tbl_contrato_mandante {
  idcontrato            Int       @id @default(autoincrement())
  idmandante            Int
  fechaInicio           DateTime
  fechaFin              DateTime?
  permitePagoAnticipado Boolean   @default(true) // Ley 842/1061 Art.68
  estado                Boolean   @default(true)
  deletedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  mandante tbl_mandante @relation(fields: [idmandante], references: [idmandante])

  @@index([idmandante])
  @@map("tbl_contrato_mandante")
}

model tbl_comision_cobro {
  idcomision   Int       @id @default(autoincrement())
  idmandante   Int
  tramoMoraMin Int
  tramoMoraMax Int?
  porcentaje   Decimal   @db.Decimal(5, 2) // % recuperación para la empresa
  estado       Boolean   @default(true)
  vigenteDesde DateTime  @default(now())
  vigenteHasta DateTime?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  mandante tbl_mandante @relation(fields: [idmandante], references: [idmandante])

  @@index([idmandante])
  @@index([idmandante, vigenteDesde, vigenteHasta])
  @@map("tbl_comision_cobro")
}

model tbl_campana {
  idcampana  Int       @id @default(autoincrement())
  idmandante Int
  nombre     String
  fechaCorte DateTime // FechaCierre del origen (snapshot)
  fechaCarga DateTime  @default(now())
  estado     String    @default("ACTIVA") // ACTIVA / INACTIVA / CERRADA
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  mandante  tbl_mandante       @relation(fields: [idmandante], references: [idmandante])
  prestamos tbl_prestamo[]
  cargas    tbl_carga_cartera[]
  importacionJobs tbl_importacion_job[]
  secuenciasContacto tbl_secuencia_contacto[]

  @@index([idmandante, estado])
  @@map("tbl_campana")
}

// ============================================
// COBRANZA · PRÉSTAMO / CARTERA
// ============================================

model tbl_prestamo {
  idprestamo       Int  @id @default(autoincrement())
  idmandante       Int
  idcampana        Int?
  idcliente        Int // deudor/titular (tbl_cliente)
  idtipocredito    Int?
  idmodelopago     Int?
  idruta           Int?
  idagencia        Int?
  idgestorAsignado    Int? // tbl_usuario
  bloqueadoAsignacion Boolean @default(false)

  noPrestamo       String
  /// Identificador externo del mandante; único por acreedor (H29).
  codigoUnico      String
  noCuenta         String?
  plazoMeses       Int?
  fechaPrestamo    DateTime?
  fechaVencimiento DateTime?
  estado           String // Vigente / Vencido / Cancelado / Castigo

  // Moneda y mantenimiento de valor (indexación al dólar)
  moneda     String   @default("NIO") // NIO / USD
  tipoCambio Decimal? @db.Decimal(10, 4)

  // Valores IMPORTADOS del mandante (no calculados por el sistema)
  saldoTotal      Decimal   @default(0) @db.Decimal(14, 2)
  montoPrestamo   Decimal   @default(0) @db.Decimal(14, 2)
  diasMora        Int       @default(0)
  ultimaFechaPago DateTime?

  // Desglose financiero importado
  interes            Decimal @default(0) @db.Decimal(14, 2)
  interesMoratorio   Decimal @default(0) @db.Decimal(14, 2)
  comisionCav        Decimal @default(0) @db.Decimal(14, 2)
  comisionInsitu     Decimal @default(0) @db.Decimal(14, 2)
  mantenimientoValor Decimal @default(0) @db.Decimal(14, 2)
  gestionCobranza    Decimal @default(0) @db.Decimal(14, 2)
  seguroSvsd         Decimal @default(0) @db.Decimal(14, 2)
  cargosAdmin        Decimal @default(0) @db.Decimal(14, 2)
  devolucionSaldoFavor Decimal @default(0) @db.Decimal(14, 2)
  descuentosArchivo    Decimal @default(0) @db.Decimal(14, 2)

  reportableCentralRiesgo Boolean @default(true) // false si hay acuerdo vigente

  /// Lock optimista para updates concurrentes (I019).
  version Int @default(0)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  mandante    tbl_mandante     @relation(fields: [idmandante], references: [idmandante])
  campana     tbl_campana?     @relation(fields: [idcampana], references: [idcampana])
  cliente     tbl_cliente      @relation(fields: [idcliente], references: [idcliente])
  tipocredito tbl_tipocredito? @relation(fields: [idtipocredito], references: [idtipocredito])
  modelopago  tbl_modelopago?  @relation(fields: [idmodelopago], references: [idmodelopago])
  ruta        tbl_ruta?        @relation(fields: [idruta], references: [idruta])
  agencia     tbl_agencia?     @relation(fields: [idagencia], references: [idagencia])
  gestor      tbl_usuario?     @relation(fields: [idgestorAsignado], references: [idusuario])

  cortes     tbl_prestamo_corte[]
  fiadores   tbl_fiador[]
  gestiones  tbl_gestion[]
  acuerdos   tbl_acuerdo[]
  pagos      tbl_pago[]
  reclamos              tbl_reclamo[]
  documentos            tbl_documento[]
  historialAsignaciones tbl_prestamo_asignacion_historial[]
  historialEstados      tbl_prestamo_estado_historial[]
  cuotas                tbl_prestamo_cuota[]
  liquidacionDetalles   tbl_liquidacion_detalle[]
  refinanciamientosOrigen tbl_refinanciamiento[] @relation("RefinanciamientoOrigen")
  refinanciamientosNuevo  tbl_refinanciamiento[] @relation("RefinanciamientoNuevo")

  @@unique([idmandante, noPrestamo])
  @@unique([idmandante, codigoUnico])
  @@index([idmandante, estado])
  @@index([idcliente])
  @@index([idgestorAsignado])
  @@index([idgestorAsignado, deletedAt, diasMora])
  @@index([idmandante, diasMora, deletedAt])
  @@index([idcampana])
  @@map("tbl_prestamo")
}

/// Cuotas del crédito importado (distintas de tbl_acuerdo_cuota) — I031.
model tbl_prestamo_cuota {
  idcuota          Int       @id @default(autoincrement())
  idprestamo       Int
  numero           Int
  fechaVencimiento DateTime
  monto            Decimal   @db.Decimal(14, 2)
  saldo            Decimal   @db.Decimal(14, 2)
  estado           String    @default("PENDIENTE") // PENDIENTE / PAGADA / VENCIDA / ANULADA
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  prestamo tbl_prestamo @relation(fields: [idprestamo], references: [idprestamo], onDelete: Cascade)

  @@unique([idprestamo, numero])
  @@index([idprestamo, estado])
  @@index([fechaVencimiento, estado])
  @@map("tbl_prestamo_cuota")
}

/// Refinanciamiento: cierra origen y opcionalmente vincula préstamo nuevo — I030.
model tbl_refinanciamiento {
  idrefinanciamiento Int       @id @default(autoincrement())
  idmandante         Int
  idprestamoOrigen   Int
  idprestamoNuevo    Int?
  montoRefinanciado  Decimal   @db.Decimal(14, 2)
  fecha              DateTime  @default(now())
  estado             String    @default("APLICADO") // BORRADOR / APLICADO / ANULADO
  motivo             String?   @db.Text
  idusuario          Int?
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  mandante       tbl_mandante @relation(fields: [idmandante], references: [idmandante])
  prestamoOrigen tbl_prestamo @relation("RefinanciamientoOrigen", fields: [idprestamoOrigen], references: [idprestamo])
  prestamoNuevo  tbl_prestamo? @relation("RefinanciamientoNuevo", fields: [idprestamoNuevo], references: [idprestamo])

  @@index([idmandante])
  @@index([idprestamoOrigen])
  @@index([estado, deletedAt])
  @@map("tbl_refinanciamiento")
}

model tbl_prestamo_corte {
  idcorte    Int      @id @default(autoincrement())
  idprestamo Int
  idcarga    Int?
  fechaCorte DateTime
  saldoTotal Decimal  @db.Decimal(14, 2)
  diasMora   Int
  estado     String
  createdAt  DateTime @default(now())

  prestamo tbl_prestamo     @relation(fields: [idprestamo], references: [idprestamo], onDelete: Cascade)
  carga    tbl_carga_cartera? @relation(fields: [idcarga], references: [idcarga])

  @@index([idprestamo, fechaCorte])
  @@index([idcarga])
  @@map("tbl_prestamo_corte")
}

model tbl_carga_cartera {
  idcarga               Int       @id @default(autoincrement())
  idmandante            Int
  idcampana             Int
  idusuario             Int
  nombreArchivo         String
  fechaCorte            DateTime
  estado                String    @default("VIGENTE") // VIGENTE / INACTIVA / REVERTIDA
  totalPrestamos        Int       @default(0)
  prestamosNuevos       Int       @default(0)
  prestamosActualizados Int       @default(0)
  prestamosSaldoCambiado Int      @default(0)
  prestamosErrores      Int       @default(0)
  prestamosAusentes     Int       @default(0)
  saldoTotal            Decimal   @default(0) @db.Decimal(14, 2)
  tiempoMs              Int?
  resumenDiff           String?   @db.Text
  detalleCarga          String?   @db.Text
  motivoReversion       String?
  idusuarioReversion    Int?
  fechaReversion        DateTime?
  createdAt             DateTime  @default(now())

  mandante tbl_mandante       @relation(fields: [idmandante], references: [idmandante])
  campana  tbl_campana        @relation(fields: [idcampana], references: [idcampana])
  usuario  tbl_usuario        @relation(fields: [idusuario], references: [idusuario])
  cortes   tbl_prestamo_corte[]

  @@index([idmandante, estado])
  @@index([idcampana])
  @@map("tbl_carga_cartera")
}

model tbl_prestamo_asignacion_historial {
  idhistorial      Int      @id @default(autoincrement())
  idprestamo       Int
  idgestorAnterior Int?
  idgestorNuevo    Int
  idusuario        Int
  motivo           String?
  createdAt        DateTime @default(now())

  prestamo       tbl_prestamo @relation(fields: [idprestamo], references: [idprestamo], onDelete: Cascade)
  gestorAnterior tbl_usuario? @relation("gestor_anterior", fields: [idgestorAnterior], references: [idusuario])
  gestorNuevo    tbl_usuario  @relation("gestor_nuevo", fields: [idgestorNuevo], references: [idusuario])
  usuario        tbl_usuario  @relation("usuario_asignacion", fields: [idusuario], references: [idusuario])

  @@index([idprestamo, createdAt])
  @@map("tbl_prestamo_asignacion_historial")
}

