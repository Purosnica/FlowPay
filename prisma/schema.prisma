model tbl_notificacion {
  idnotificacion Int       @id @default(autoincrement())
  idusuario      Int
  tipo           String
  severidad      String    @default("info")
  titulo         String
  mensaje        String    @db.Text
  url            String?
  entidad        String?
  entidadId      Int?
  leida          Boolean   @default(false)
  leidaEn        DateTime?
  /// Outbox email: null = sin email; PENDIENTE | ENVIADO | FALLIDO (I033).
  emailEstado    String?
  emailIntentos  Int       @default(0)
  emailError     String?   @db.Text
  createdAt      DateTime  @default(now())

  usuario tbl_usuario @relation(fields: [idusuario], references: [idusuario], onDelete: Cascade)

  @@index([idusuario, leida, createdAt])
  @@index([idusuario, createdAt])
  @@index([emailEstado, createdAt])
  @@map("tbl_notificacion")
}

model tbl_usuario_mandante {
  idum               Int      @id @default(autoincrement())
  idusuario          Int
  idmandante         Int
  porcentajeComision Decimal? @db.Decimal(5, 2) // override por mandante; null = usar default del usuario
  createdAt          DateTime @default(now())

  usuario  tbl_usuario  @relation(fields: [idusuario], references: [idusuario], onDelete: Cascade)
  mandante tbl_mandante @relation(fields: [idmandante], references: [idmandante], onDelete: Cascade)

  @@unique([idusuario, idmandante])
  @@index([idmandante])
  @@index([idusuario])
  @@map("tbl_usuario_mandante")
}

// ============================================
// RENDIMIENTO · RESUMEN DIARIO MATERIALIZADO
// ============================================

model tbl_resumen_diario_cobranza {
  idresumen               Int      @id @default(autoincrement())
  idmandante              Int
  fecha                   DateTime @db.Date
  totalPrestamos          Int      @default(0)
  prestamosEnMora         Int      @default(0)
  saldoCartera            Decimal  @default(0) @db.Decimal(18, 2)
  saldoMora               Decimal  @default(0) @db.Decimal(18, 2)
  gestionesDia            Int      @default(0)
  pagosDia                Int      @default(0)
  montoRecuperadoDia      Decimal  @default(0) @db.Decimal(18, 2)
  promesasVencidas        Int      @default(0)
  acuerdosEnRiesgo        Int      @default(0)
  reclamosFueraSla        Int      @default(0)
  recuperacionMesActual   Decimal  @default(0) @db.Decimal(18, 2)
  recuperacionMesAnterior Decimal  @default(0) @db.Decimal(18, 2)
  calculatedAt            DateTime @default(now())
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  mandante tbl_mandante @relation(fields: [idmandante], references: [idmandante])

  @@unique([idmandante, fecha])
  @@index([fecha])
  @@map("tbl_resumen_diario_cobranza")
}

// ============================================
// RENDIMIENTO · EXPORTS ASYNC (>10k filas)
// ============================================

model tbl_exportacion_job {
  idexport     Int       @id @default(autoincrement())
  idmandante   Int?
  idusuario    Int
  tipo         String
  estado       String    @default("PENDIENTE")
  parametros   String?   @db.Text
  filasEstimadas Int     @default(0)
  progresoPct  Int       @default(0)
  rutaArchivo  String?
  nombreArchivo String?
  error        String?   @db.Text
  iniciadoEn   DateTime?
  finalizadoEn DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  mandante tbl_mandante? @relation(fields: [idmandante], references: [idmandante])
  usuario  tbl_usuario   @relation(fields: [idusuario], references: [idusuario])

  @@index([estado, createdAt])
  @@index([idusuario, createdAt])
  @@map("tbl_exportacion_job")
}

// ============================================
// ARQUITECTURA · FEATURE FLAGS + DOMAIN EVENTS (I007 / I012)
// ============================================

/// Flag por mandante; idmandante=0 = global (I012).
model tbl_feature_flag {
  idflag     Int      @id @default(autoincrement())
  clave      String   @db.VarChar(64)
  idmandante Int      @default(0)
  activo     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([clave, idmandante])
  @@index([clave])
  @@map("tbl_feature_flag")
}

/// Outbox de eventos de dominio (I007).
model tbl_domain_event {
  idevento     Int       @id @default(autoincrement())
  tipo         String    @db.VarChar(64)
  payload      String    @db.Text
  idmandante   Int?
  estado       String    @default("PENDIENTE") @db.VarChar(20)
  intentos     Int       @default(0)
  error        String?   @db.Text
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([estado, createdAt])
  @@index([tipo, createdAt])
  @@map("tbl_domain_event")
}
