model tbl_importacion_job {
  idjob           Int       @id @default(autoincrement())
  idmandante      Int
  idcampana       Int?
  idusuario       Int
  tipo            String
  estado          String    @default("PENDIENTE")
  nombreArchivo   String
  rutaArchivo     String
  /** Payload temporal del archivo (Vercel / multi-instancia). Se libera al finalizar. */
  contenidoArchivo Bytes?
  fechaCorte      DateTime?
  nombreHoja      String?
  idplantillaImp  Int?
  progresoPct     Int       @default(0)
  filasProcesadas Int       @default(0)
  filasTotales    Int       @default(0)
  intentos        Int       @default(0)
  deadLetterAt    DateTime?
  resultado       String?   @db.Text
  error           String?   @db.Text
  /** Idempotency-Key HTTP (I059); único por usuario. */
  idempotencyKey  String?   @db.VarChar(64)
  iniciadoEn      DateTime?
  finalizadoEn    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  mandante tbl_mandante  @relation(fields: [idmandante], references: [idmandante])
  campana  tbl_campana?  @relation(fields: [idcampana], references: [idcampana])
  usuario  tbl_usuario   @relation(fields: [idusuario], references: [idusuario])

  @@unique([idusuario, idempotencyKey])
  @@index([estado, createdAt])
  @@index([idmandante])
  @@index([estado, deadLetterAt])
  @@map("tbl_importacion_job")
}

