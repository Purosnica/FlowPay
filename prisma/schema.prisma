  autorizado  Boolean   @default(false) // sólo contactar si true (Ley 787)
  esTercero   Boolean   @default(false) // marca sensible (SIBOIF / Ley 787)
  noContactar Boolean   @default(false)
  estado      Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  cliente tbl_cliente @relation(fields: [idcliente], references: [idcliente])

  @@index([idcliente])
  @@map("tbl_deudor_contacto")
}

model tbl_fiador {
