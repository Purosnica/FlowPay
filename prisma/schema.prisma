  @@index([idmandante])
  @@index([idcliente])
  @@index([deletedAt, estado, fechaLimite])
  @@index([idmandante, estado, fechaLimite])
  @@map("tbl_reclamo")
}

model tbl_documento {
  iddocumento Int       @id @default(autoincrement())
  idprestamo  Int?
  idcliente   Int?
  tipo        String // RECIBO / PODER / EVIDENCIA / GRABACION / CONTRATO
  url         String
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

