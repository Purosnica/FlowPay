# Copiar a .env y completar. Nunca commitear .env.

DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"
# Recomendado en hosting remoto (timeouts de conexión):
# DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE?connect_timeout=10"
JWT_SECRET="cambiar-por-secreto-de-al-menos-32-caracteres"
# Obligatorio en todos los entornos (H26). Mín. 16 en desarrollo; 32 en producción.
# Sin fallback hardcodeado.
CRON_SECRET="cambiar-por-secreto-de-al-menos-16-caracteres"

# Raíz de almacenamiento de documentos/uploads (H29).
# En multi-instancia use un volumen compartido o NFS montado aquí.
# Por defecto: <tmpdir>/flowpay-storage
# FLOWPAY_STORAGE_ROOT="/var/flowpay/storage"
# Vacío = same-origin (obligatorio en producción / Vercel).
# Si lo apuntas a otro host (p. ej. *.vercel.app) mientras sirves desde
# dominio custom o preview, el CSP connect-src 'self' bloqueará GraphQL.
# NEXT_PUBLIC_API_URL=
# Solo en desarrollo si el API corre en otro origen/puerto:
# NEXT_PUBLIC_API_URL="http://localhost:3001"

# Producción detrás de reverse proxy: habilitar IP confiable
# (Vercel / proxy: TRUST_PROXY=true). Sin esto no se usan X-Forwarded-For.
# TRUST_PROXY=true

# Idle de sesión (segundos). Default 1800 (30 min). Absoluto JWT sigue en 8h.
# SESSION_IDLE_SECONDS=1800

# I107: CDN / assetPrefix opcional (vacío = origen / Vercel edge).
# NEXT_PUBLIC_ASSET_PREFIX=https://cdn.example.com

# Límites GraphQL (DoS)
# GRAPHQL_MAX_DEPTH=12
# GRAPHQL_MAX_FIELDS=250
# GRAPHQL_MAX_COST=1000
# GRAPHQL_LIST_COST_DEFAULT=10
# GRAPHQL_PERSISTED_ONLY=true

# SMTP opcional (App Password Google: 16 chars SIN espacios)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_FROM_NAME=Cobranza

# Sentry opcional (tier gratis). Vacío = desactivado.
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=

# Workers Node (I001) — preferidos en self-host; Vercel cron = fallback
# WORKER_CRON_INTERVAL_MS=300000
# WORKER_QUEUE_INTERVAL_MS=15000
# IMPORT_MAX_JOBS_PER_RUN=1
# IMPORT_MAX_CONCURRENT=1
