# Copiar a .env y completar. Nunca commitear .env.

DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"
JWT_SECRET="cambiar-por-secreto-de-al-menos-32-caracteres"
CRON_SECRET="cambiar-por-secreto-de-al-menos-16-caracteres"
# Vacío = same-origin (obligatorio en producción / Vercel).
# Si lo apuntas a otro host (p. ej. *.vercel.app) mientras sirves desde
# dominio custom o preview, el CSP connect-src 'self' bloqueará GraphQL.
# NEXT_PUBLIC_API_URL=
# Solo en desarrollo si el API corre en otro origen/puerto:
# NEXT_PUBLIC_API_URL="http://localhost:3001"

# Producción detrás de reverse proxy: habilitar IP confiable
# TRUST_PROXY=true

# SMTP opcional (App Password Google: 16 chars SIN espacios)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_FROM_NAME=Cobranza
